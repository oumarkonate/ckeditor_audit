# Copy this file to .env and fill in the values for your project.
# .env is not versioned — each user maintains their own.

# Required — absolute path to the project being audited
CKEDITOR_AUDIT_PROJECT_ROOT=/path/to/your/project

# Optional — additional globs (comma-separated) to search for plugin usages
# beyond the default CKEDITOR_AUDIT_CONFIGS_GLOB.
# Useful for entry files, YAML configs, PHP constants, JS plugin registries, etc.
# CKEDITOR_AUDIT_EXTRA_GLOBS=

# Optional overrides (defaults shown)
# CKEDITOR_AUDIT_PLUGINS_GLOB=assets/ckeditor/ckeditor5-*
# CKEDITOR_AUDIT_CONFIGS_GLOB=assets/config/ckeditor/*_config.js
# CKEDITOR_AUDIT_LEGACY_LABEL=legacy
# CKEDITOR_AUDIT_TARGET_LABEL=latest